# ═══════════════════════════════════════════════════════
# VoiceTranslate — Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════

# ── App ──
NEXT_PUBLIC_URL=https://voice-translator2.vercel.app

# ── Supabase (Database + Auth) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Redis (Upstash — legacy session/credit store) ──
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── AI Translation Providers ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── TTS (Text-to-Speech) ──
ELEVENLABS_API_KEY=sk_...

# ── Email (Resend) ──
RESEND_API_KEY=re_...
RESEND_FROM=VoiceTranslate <noreply@voicetranslate.app>

# ── OAuth ──
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Apple Sign-In — enable only after App Store publication
# APPLE_CLIENT_ID=com.yourapp.auth
# NEXT_PUBLIC_APPLE_CLIENT_ID=com.yourapp.auth

# ── Stripe (Payments & Subscriptions) ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_BIZ_MONTHLY=price_...
STRIPE_PRICE_BIZ_YEARLY=price_...

# ── Security ──
ENCRYPTION_KEY=your-32-char-hex-encryption-key
KEY_VAULT_SECRET=your-64-char-hex-key-for-api-key-encryption
ALLOWED_ORIGIN=https://voice-translator2.vercel.app

# ── Admin ──
ADMIN_EMAILS=admin@example.com,admin2@example.com
ADMIN_PASS=your-admin-password

# ── Error Tracking (Sentry) ──
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=voicetranslate
SENTRY_PROJECT=voicetranslate
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── Streaming STT (Deepgram — optional, enables real-time WebSocket transcription) ──
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── WebRTC TURN Server (optional, for NAT traversal in P2P calls) ──
# Free option: Cloudflare TURN (https://developers.cloudflare.com/calls/turn/)
NEXT_PUBLIC_TURN_URL=turn:turn.example.com:3478
NEXT_PUBLIC_TURN_USER=your-turn-username
NEXT_PUBLIC_TURN_PASS=your-turn-password

# ── Analytics (Plausible) ──
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=voicetranslate.app
