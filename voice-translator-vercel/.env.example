# ═══════════════════════════════════════════════════════
# VoiceTranslate — Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════

# ── App ──
NEXT_PUBLIC_URL=https://voicetranslate.app

# ── Supabase (Database + Auth) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Redis (Upstash — legacy session/credit store) ──
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── AI Translation Providers ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── TTS (Text-to-Speech) ──
ELEVENLABS_API_KEY=sk_...

# ── Email (Resend) ──
RESEND_API_KEY=re_...
RESEND_FROM=VoiceTranslate <noreply@voicetranslate.app>

# ── OAuth ──
GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com
APPLE_CLIENT_ID=com.yourapp.auth
NEXT_PUBLIC_APPLE_CLIENT_ID=com.yourapp.auth

# ── Stripe (Payments & Subscriptions) ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_BIZ_MONTHLY=price_...
STRIPE_PRICE_BIZ_YEARLY=price_...

# ── Security ──
ENCRYPTION_KEY=your-32-char-hex-encryption-key
ALLOWED_ORIGIN=https://voicetranslate.app

# ── Admin ──
ADMIN_EMAILS=admin@example.com,admin2@example.com
ADMIN_PASS=your-admin-password

# ── Error Tracking (Sentry) ──
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=voicetranslate
SENTRY_PROJECT=voicetranslate
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── Analytics (Plausible) ──
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=voicetranslate.app
